<?xml version="1.0" ?>
<mujoco model="nuclear_glovebox_shadow">
  <!-- Top-level compiler: mesh dir points at the vendored Shadow Hand assets. -->
  <compiler angle="radian" meshdir="../assets/shadow_hand/assets" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81" cone="elliptic" impratio="10" integrator="implicitfast"/>

  <visual>
    <global offwidth="1920" offheight="1080" azimuth="140" elevation="-20"/>
    <quality shadowsize="4096"/>
  </visual>

  <!-- Pull in the Shadow Hand (right) mounted on its movable carriage. -->
  <include file="../assets/shadow_hand/right_hand.xml"/>

  <asset>
    <texture name="skybox" type="skybox" builtin="gradient" rgb1="0.3 0.4 0.55" rgb2="0.05 0.07 0.1" width="512" height="512"/>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.15 0.18 0.22" rgb2="0.25 0.28 0.33" width="300" height="300"/>
    <material name="grid" texture="grid" texrepeat="6 6" reflectance="0.2"/>
    <material name="glovebox_mat" rgba="0.55 0.58 0.62 1" reflectance="0.3"/>
    <material name="vial_red" rgba="0.9 0.12 0.12 1" reflectance="0.1"/>
    <material name="vial_cap" rgba="0.95 0.85 0.2 1" reflectance="0.1"/>
    <material name="container_mat" rgba="0.2 0.7 0.4 1" reflectance="0.2"/>
    <material name="pedestal_mat" rgba="0.4 0.42 0.46 1" reflectance="0.2"/>
    <material name="rack_mat" rgba="0.30 0.33 0.40 1" reflectance="0.25"/>
    <material name="hole_mat" rgba="0.05 0.06 0.08 1" reflectance="0.0"/>
  </asset>

  <worldbody>
    <light name="top" pos="0 0 1.4" dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3"/>
    <light name="side" pos="0.5 -0.6 1.0" dir="-0.5 0.6 -1.0" diffuse="0.4 0.4 0.4"/>
    <geom name="ground" type="plane" size="2 2 0.05" material="grid"/>

    <!-- Glovebox work floor (visual context) -->
    <body name="glovebox_floor" pos="0.08 0 0">
      <geom type="box" size="0.4 0.32 0.008" pos="0 0 0.004" material="glovebox_mat"/>
    </body>

    <!-- Sample tube rack: a base block with sockets; the front socket holds
         the vial. The near-vial support stub stays narrow (r=0.02, top z=0.10)
         so the fingers clear it during the grasp. -->
    <body name="sample_rack" pos="0 0 0">
      <!-- narrow support stub holding the vial (top z=0.10) -->
      <geom type="cylinder" size="0.02 0.05" pos="0 0 0.05" material="rack_mat"/>
    </body>

    <!-- Sample vial: narrow body + wide flanged cap, FREE joint (real physics) -->
    <body name="sample_vial" pos="0 0 0.145">
      <freejoint name="vial_free"/>
      <inertial pos="0 0 0.01" mass="0.03" diaginertia="3e-5 3e-5 5e-6"/>
      <geom name="vial_body" type="cylinder" size="0.013 0.045" material="vial_red"
            friction="1.6 0.1 0.05" solref="0.008 1" solimp="0.95 0.98 0.001"/>
      <geom name="vial_cap" type="cylinder" size="0.032 0.007" pos="0 0 0.05" material="vial_cap"
            friction="1.6 0.1 0.05"/>
    </body>

    <!-- Shielded container (drop target): wide open bin the hand can reach into -->
    <body name="shielded_container" pos="0.32 0 0">
      <geom type="box" size="0.09 0.09 0.005" pos="0 0 0.005" material="container_mat"/>
      <geom type="box" size="0.09 0.006 0.04" pos="0 0.09 0.04" material="container_mat"/>
      <geom type="box" size="0.09 0.006 0.04" pos="0 -0.09 0.04" material="container_mat"/>
      <geom type="box" size="0.006 0.09 0.04" pos="0.09 0 0.04" material="container_mat"/>
      <geom type="box" size="0.006 0.09 0.04" pos="-0.09 0 0.04" material="container_mat"/>
    </body>
  </worldbody>
</mujoco>
