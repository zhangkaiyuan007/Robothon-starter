<?xml version="1.0" ?>
<mujoco model="sample_vial">
  <compiler angle="radian"/>

  <asset>
    <material name="red_vial" rgb="0.8 0.1 0.1" reflectance="0.2"/>
  </asset>

  <worldbody>
    <!-- Sample vial with cylindrical body and cap -->
    <body name="sample_vial_body" pos="-0.15 0.3 0.1">
      <inertial mass="0.05" diaginv="400 400 400"/>
      <!-- Cylinder body (radius 0.01, height 0.03) -->
      <geom type="cylinder" size="0.01 0.03" material="red_vial"/>
      <!-- Box cap (small box on top) -->
      <geom type="box" size="0.008 0.008 0.005" pos="0 0 0.035" material="red_vial"/>
    </body>
  </worldbody>
</mujoco>
